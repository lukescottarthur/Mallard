> # WMAxKC - pcadapt whole genome analysis - revised for cross analysis comparison. This script calculates pcadapt p-values across sliding windows and outputs them into a csv file.
> 
> # load libraries
> library(pcadapt)
> library(ggplot2)
> library(qqman)
> library(ggrepel)
> library(dplyr)
> library(devtools)
> 
> 
> # Read and prepare data
> bed <- read.pcadapt("/home/las80898/mallard_wholegenome_data/WMxKC.bed", type = "bed")
> 
> x1 <- pcadapt(bed, K = 2, min.maf = 0.02)
